<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".UI.Auth.forgetpassword.VerificationActivity">


    <ImageView
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:id="@+id/backButton"
        android:contentDescription="@string/back_button"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:src="@drawable/back_button"
        android:layout_margin="22dp"
        />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/tvVerificationCode"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/backButton"
        android:text="@string/verification_code"
        android:textSize="28sp"
        android:textStyle="bold"
        />

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="300dp"
        android:id="@+id/ivForget"
        android:contentDescription="@string/forget_password_image"
        android:src="@drawable/forget"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvVerificationCode"
        />

    <LinearLayout
        android:id="@+id/llOtpContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="30dp"
        android:paddingHorizontal="20dp"
        app:layout_constraintTop_toBottomOf="@id/ivForget"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/etDigit1"
            android:layout_width="80dp"
            android:layout_height="100dp"
            android:layout_margin="8dp"
            android:background="@drawable/otp_box_background"
            android:gravity="center"
            android:inputType="number"
            android:digits="0123456789"
            android:imeOptions="actionNext"
            android:maxLength="1"
            android:textSize="24sp"
            android:textStyle="bold"
            tools:text="7" />

        <EditText
            android:id="@+id/etDigit2"
            android:layout_width="80dp"
            android:layout_height="100dp"
            android:layout_margin="8dp"
            android:background="@drawable/otp_box_background"
            android:gravity="center"
            android:inputType="number"
            android:digits="0123456789"
            android:imeOptions="actionNext"
            android:maxLength="1"
            android:textSize="24sp"
            android:textStyle="bold"
            tools:text="4" />

        <EditText
            android:id="@+id/etDigit3"
            android:layout_width="80dp"
            android:layout_height="100dp"
            android:layout_margin="8dp"
            android:background="@drawable/otp_box_background"
            android:gravity="center"
            android:inputType="number"
            android:digits="0123456789"
            android:imeOptions="actionNext"
            android:maxLength="1"
            android:textSize="24sp"
            android:textStyle="bold"
            tools:text="2" />

        <EditText
            android:id="@+id/etDigit4"
            android:layout_width="80dp"
            android:layout_height="100dp"
            android:layout_margin="8dp"
            android:background="@drawable/otp_box_background"
            android:gravity="center"
            android:inputType="number"
            android:digits="0123456789"
            android:imeOptions="actionDone"
            android:maxLength="1"
            android:textSize="24sp"
            android:textStyle="bold"
            tools:text="3" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:id="@+id/lTimer"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/llOtpContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/_00_20"
            android:textStyle="bold"
            android:textColor="@android:color/black" />

        <TextView
            android:id="@+id/tvResend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/resend_confirmation_code"
            android:layout_marginStart="5dp"
            android:textColor="#9E9E9E" />

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirmEmail"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="@string/confirm_code"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_custom_button"
        app:backgroundTint="@null"
        android:layout_marginStart="60dp"
        android:layout_marginEnd="60dp"
        android:layout_marginTop="30dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/lTimer"/>


    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="200dp"
        android:contentDescription="@string/upper_splash_image"
        android:src="@drawable/lower_login"
        android:id="@+id/image_lower_login"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        />




</androidx.constraintlayout.widget.ConstraintLayout>