<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    >

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:id="@+id/ivReviewer"
            android:contentDescription="@string/person"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:src="@drawable/icon_rev"
            />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/layoutNameTime"
            android:orientation="vertical"
            app:layout_constraintTop_toTopOf="@id/ivReviewer"
            app:layout_constraintBottom_toBottomOf="@id/ivReviewer"
            app:layout_constraintStart_toEndOf="@id/ivReviewer"
            android:layout_marginStart="20dp"
            >

            <TextView
                android:id="@+id/tvReviewerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reviewer_name"
                android:textSize="14sp"
                android:textColor="@color/black"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:id="@+id/layoutTime"
                >

                <ImageView
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:src="@drawable/time"
                    />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/tvReviewTime"
                    android:text="@string/_13_sep_2020"
                    android:layout_marginStart="5dp"
                    android:textColor="@color/gray"
                    android:textSize="11sp"
                    />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/layoutRate"
            android:orientation="vertical"
            app:layout_constraintTop_toTopOf="@id/layoutNameTime"
            app:layout_constraintBottom_toBottomOf="@id/layoutNameTime"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="20dp"
            >

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:id="@+id/layoutRateNumber"
                >

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/tvRateNumber"
                    android:text="@string/_4"
                    android:layout_marginStart="5dp"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/tvRateText"
                    android:text="@string/rating"
                    android:layout_marginStart="5dp"
                    android:textColor="@color/gray"
                    android:textSize="11sp"
                    />

            </LinearLayout>

            <RatingBar
                android:id="@+id/ratingBar"
                style="?android:attr/ratingBarStyleSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:numStars="5"
                android:progressTint="#FFB300"
                android:rating="3.5"
                app:layout_constraintStart_toStartOf="@+id/ratingValue"
                app:layout_constraintTop_toBottomOf="@id/ratingValue" />

        </LinearLayout>


        <TextView
            android:id="@+id/tvReviewerDiscription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/discription"
            android:textAlignment="textStart"
            android:textColor="@color/gray"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@+id/layoutRate"
            app:layout_constraintStart_toStartOf="@+id/ivReviewer"
            app:layout_constraintTop_toBottomOf="@id/layoutRate" />


    </androidx.constraintlayout.widget.ConstraintLayout>



</androidx.cardview.widget.CardView>