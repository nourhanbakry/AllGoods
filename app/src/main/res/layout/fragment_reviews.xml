<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/white"
    android:fitsSystemWindows="true"
    tools:context=".UI.Seller.Reviews.ReviewsFragment">

    <TextView
        android:id="@+id/tvCustomerReviews"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/customer_reviews"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_marginStart="22dp"
        android:layout_marginTop="22dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/tvProductsCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/_3_reviews"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:background="@drawable/bg_black_rounded"
        android:layout_marginEnd="22dp"
        app:layout_constraintTop_toTopOf="@id/tvCustomerReviews"
        app:layout_constraintBottom_toBottomOf="@id/tvCustomerReviews"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvRatingSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="22dp"
        android:layout_marginTop="20dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/white"
        app:strokeColor="@color/gray"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/tvCustomerReviews">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- الجزء الأيسر: المعدل العام والنجوم -->
            <LinearLayout
                android:id="@+id/llAverageRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/tvRatingValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4.7"
                    android:textColor="@color/black"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <RatingBar
                    android:id="@+id/rbAverage"
                    style="?android:attr/ratingBarStyleSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:numStars="5"
                    android:rating="4.7"
                    android:stepSize="0.1"
                    android:progressTint="#FFC107" />

                <TextView
                    android:id="@+id/tvTotalReviewsDetail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="3 reviews"
                    android:textColor="#888888"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- الجزء الأيمن: تفاصيل الخمس نجوم -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/llAverageRating"
                app:layout_constraintTop_toTopOf="parent">

                <include layout="@layout/item_rating_progress" />
                <include layout="@layout/item_rating_progress" />
                <include layout="@layout/item_rating_progress" />
                <include layout="@layout/item_rating_progress" />
                <include layout="@layout/item_rating_progress" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>




</androidx.constraintlayout.widget.ConstraintLayout>