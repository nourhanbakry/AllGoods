<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".UI.Customer.Cart.Address.AddressFragment"
    android:background="@color/white"
    android:fitsSystemWindows="true">

    <ImageView
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:id="@+id/backButtonAddress"
        android:contentDescription="@string/back_button"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:src="@drawable/back_button"
        android:layout_margin="22dp"
        />

    <TextView
        android:id="@+id/tvReviews"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/address"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/backButtonAddress"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/backButtonAddress"
        />


    <TextView
        android:id="@+id/tvNameReviewer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/name"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvReviews"
        android:layout_margin="22dp"
        />

    <EditText
        android:id="@+id/etName"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:paddingStart="15dp"
        android:paddingEnd="15dp"
        android:layout_marginStart="22dp"
        android:layout_marginEnd="22dp"
        android:layout_marginTop="10dp"
        android:drawablePadding="10dp"
        android:background="@drawable/bg_gray_fa"
        android:gravity="center_vertical"
        android:hint="@string/mrh_raju"
        android:textColor="@color/black"
        android:textColorHint="@color/gray9E"
        app:layout_constraintTop_toBottomOf="@id/tvNameReviewer"
        app:layout_constraintStart_toStartOf="parent"
        android:inputType="text"
        android:maxLines="1"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvCountry"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Country"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="@+id/tvNameReviewer"
        app:layout_constraintTop_toBottomOf="@id/etName"
        android:layout_marginTop="15dp"
        />


    <EditText
        android:id="@+id/etCountry"
        android:layout_width="170dp"
        android:layout_height="50dp"
        android:paddingStart="15dp"
        android:paddingEnd="15dp"
        android:layout_marginStart="22dp"
        android:layout_marginEnd="22dp"
        android:layout_marginTop="10dp"
        android:drawablePadding="10dp"
        android:background="@drawable/bg_gray_fa"
        android:gravity="center_vertical"
        android:hint="@string/bangladesh"
        android:textColor="@color/black"
        android:textColorHint="@color/gray9E"
        app:layout_constraintTop_toBottomOf="@id/tvCountry"
        app:layout_constraintStart_toStartOf="parent"
        android:inputType="text"
        android:maxLines="1"
        />

    <TextView
        android:id="@+id/tvCity"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/city"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/tvCountry"
        app:layout_constraintStart_toStartOf="@+id/etCity"
        app:layout_constraintTop_toTopOf="@id/tvCountry" />

    <EditText
        android:id="@+id/etCity"
        android:layout_width="170dp"
        android:layout_height="50dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_gray_fa"
        android:drawablePadding="10dp"
        android:gravity="center_vertical"
        android:hint="@string/sylhet"
        android:inputType="text"
        android:maxLines="1"
        android:paddingStart="15dp"
        android:paddingEnd="15dp"
        android:textColor="@color/black"
        android:textColorHint="@color/gray9E"
        android:layout_marginStart="27dp"
        app:layout_constraintEnd_toEndOf="@+id/etName"
        app:layout_constraintStart_toEndOf="@+id/etCountry"
        app:layout_constraintTop_toBottomOf="@id/tvCity" />


    <TextView
        android:id="@+id/tvPhoneNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/phone_number"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/etCountry"
        android:layout_margin="22dp"
        />

    <EditText
        android:id="@+id/etNumberPhone"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:paddingStart="15dp"
        android:paddingEnd="15dp"
        android:layout_marginStart="22dp"
        android:layout_marginEnd="22dp"
        android:layout_marginTop="10dp"
        android:drawablePadding="10dp"
        android:background="@drawable/bg_gray_fa"
        android:gravity="center_vertical"
        android:hint="@string/_880_1453_987533"
        android:textColor="@color/black"
        android:textColorHint="@color/gray9E"
        app:layout_constraintTop_toBottomOf="@id/tvPhoneNumber"
        app:layout_constraintStart_toStartOf="parent"
        android:inputType="number"
        android:maxLines="1"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvAddressTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/address"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/etNumberPhone"
        android:layout_margin="22dp"
        />

    <EditText
        android:id="@+id/etAddress"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:paddingStart="15dp"
        android:paddingEnd="15dp"
        android:layout_marginStart="22dp"
        android:layout_marginEnd="22dp"
        android:layout_marginTop="10dp"
        android:drawablePadding="10dp"
        android:background="@drawable/bg_gray_fa"
        android:gravity="center_vertical"
        android:hint="@string/chhatak_sunamgonj_12_8ab"
        android:textColor="@color/black"
        android:textColorHint="@color/gray9E"
        app:layout_constraintTop_toBottomOf="@id/tvAddressTitle"
        app:layout_constraintStart_toStartOf="parent"
        android:inputType="text"
        android:maxLines="1"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvPrimaryAddress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/save_as_primary_address"
        android:textSize="18sp"
        android:textColor="@color/black"
        android:layout_marginTop="25dp"
        android:layout_marginStart="22dp"
        app:layout_constraintTop_toBottomOf="@id/etAddress"
        app:layout_constraintStart_toStartOf="parent" />


    <Switch
        android:id="@+id/switchPrimary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:ignore="UseSwitchCompatOrMaterialXml"
        android:thumbTint="@color/switch_thumb_selector"
        android:trackTint="@color/switch_track_selector"
        app:layout_constraintBottom_toBottomOf="@+id/tvPrimaryAddress"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tvPrimaryAddress"
        android:layout_marginEnd="22dp"
        />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="@string/save"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_custom_button"
        app:backgroundTint="@null"
        android:layout_marginStart="30dp"
        android:layout_marginEnd="30dp"
        android:layout_marginBottom="40dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        />



</androidx.constraintlayout.widget.ConstraintLayout>